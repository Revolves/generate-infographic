# SenseNova API Key (必填，向后兼容)
SENSENOVA_API_KEY=your_api_key_here
SENSENOVA_BASE_URL=https://token.sensenova.cn/v1

# === 对话模型（可选独立配置，退避到 SENSENOVA_*） ===
# CHAT_API_KEY=
# CHAT_BASE_URL=
# CHAT_MODEL=sensenova-6.7-flash-lite

# === 多模态模型（可选独立配置，退避到 CHAT_*） ===
# MULTIMODAL_API_KEY=
# MULTIMODAL_BASE_URL=
# MULTIMODAL_MODEL=sensenova-6.7-flash-lite

# === 生图模型（可选独立配置，退避到 MULTIMODAL_*） ===
# IMAGE_API_KEY=
# IMAGE_BASE_URL=
# IMAGE_MODEL=sensenova-u1-fast

# === 共享配置 ===
# 默认图片尺寸 (可选，默认 2752x1536)
IMAGE_SIZE=2752x1536
# 请求超时秒数 (可选，默认 120)
REQUEST_TIMEOUT=120
# 最大重试次数 (可选，默认 3)
MAX_RETRIES=3
# 输出目录 (可选，默认 output)
OUTPUT_DIR=output